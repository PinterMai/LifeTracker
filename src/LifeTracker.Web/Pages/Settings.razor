@page "/settings"
@using LifeTracker.Core.Interfaces
@using LifeTracker.Web.Services
@inject ISettingsService SettingsSvc
@inject IAiService Ai
@inject BrowserDbPersistence Persistence
@inject HttpClient Http

<PageTitle>Settings</PageTitle>

<div class="settings-page">
    <h1>Settings</h1>

    <section class="card">
        <h2>AI provider</h2>
        <p class="muted">
            The AI backend used for "Analyze" on trades. Gemini has a generous
            free tier — get a key at
            <a href="https://aistudio.google.com/apikey" target="_blank" rel="noopener">aistudio.google.com/apikey</a>.
        </p>

        <div class="form-row">
            <label>API key</label>
            <div class="key-row">
                <input type="@(_showKey ? "text" : "password")"
                       class="form-control"
                       @bind="_apiKey"
                       placeholder="AIza…" />
                <button type="button" class="btn btn-secondary"
                        @onclick="() => _showKey = !_showKey">
                    @(_showKey ? "Hide" : "Show")
                </button>
            </div>
            <p class="hint">Stored in this browser's localStorage. Origin-scoped, not synced anywhere.</p>
        </div>

        <div class="form-row">
            <label>Model</label>
            <input type="text" class="form-control" @bind="_model" placeholder="gemini-flash-latest" />
            <p class="hint">
                Default <code>gemini-flash-latest</code> — Google's current free-tier flash alias.
                Concrete versions like <code>gemini-1.5-flash</code> get retired and stop working on new keys.
            </p>
        </div>

        <div class="form-actions">
            <button class="btn btn-primary" @onclick="SaveAsync" disabled="@_isBusy">Save</button>
            <button class="btn btn-secondary" @onclick="TestAsync" disabled="@(_isBusy || string.IsNullOrWhiteSpace(_apiKey))">
                @(_isBusy ? "Testing…" : "Test connection")
            </button>
            @if (!string.IsNullOrEmpty(_apiKey))
            {
                <button class="btn btn-danger" @onclick="ClearAsync" disabled="@_isBusy">Remove key</button>
            }
        </div>

        @if (_status is not null)
        {
            <div class="status @_statusKind">@_status</div>
        }
    </section>

    <section class="card">
        <h2>Trusted X handles</h2>
        <p class="muted">
            Comma-separated list of X/Twitter handles (without the <code>@@</code>).
            The AI uses this as a whitelist when researching your ticker — it'll
            look at what these accounts recently posted instead of random noise.
        </p>
        <div class="form-row">
            <label>Handles</label>
            <textarea class="form-control" rows="3" @bind="_xHandles"
                      placeholder="Yeah_Dave, Kaizen_Investor, michaelsikand, …"></textarea>
            <p class="hint">Up to ~30 handles recommended. Stored in this browser only.</p>
        </div>
        <div class="form-actions">
            <button class="btn btn-primary" @onclick="SaveHandlesAsync" disabled="@_isBusy">Save handles</button>
        </div>
        @if (_handlesStatus is not null)
        {
            <div class="status @_handlesStatusKind">@_handlesStatus</div>
        }
    </section>

    <section class="card">
        <h2>Signals backend</h2>
        <p class="muted">
            Optional Cloudflare Worker URL. If set, the Signals page reads from
            the worker's daily-cron snapshot instead of calling Gemini from your
            browser — your local quota stays untouched. Setup steps live in
            <code>workers/signals/README.md</code>.
        </p>
        <div class="form-row">
            <label>Backend URL</label>
            <input type="text" class="form-control" @bind="_backendUrl"
                   placeholder="https://lifetracker-signals.your-subdomain.workers.dev" />
            <p class="hint">Leave empty to keep using direct Gemini calls from this browser.</p>
        </div>
        <div class="form-actions">
            <button class="btn btn-primary" @onclick="SaveBackendAsync" disabled="@_isBusy">Save backend URL</button>
            @if (!string.IsNullOrWhiteSpace(_backendUrl))
            {
                <button class="btn btn-secondary" @onclick="TestBackendAsync" disabled="@_isBusy">
                    @(_isBusy ? "Checking…" : "Check /health")
                </button>
            }
        </div>
        @if (_backendStatus is not null)
        {
            <div class="status @_backendStatusKind">@_backendStatus</div>
        }
    </section>

    <section class="card">
        <h2>Storage</h2>
        <p class="muted">
            Trades live in your browser's IndexedDB. On mobile, iOS Safari and
            some Android browsers evict IndexedDB after ~7 days unless the site
            gets <em>persistent storage</em>. Adding the app to your home screen
            makes the grant sticky.
        </p>
        @if (_storage is not null)
        {
            <div class="storage-grid">
                <div><span class="muted">DB size</span><strong>@FormatBytes(_storage.DbBytes)</strong></div>
                <div>
                    <span class="muted">Persistent</span>
                    @if (_storage.Persisted == true)
                    {
                        <strong class="good">granted</strong>
                    }
                    else if (_storage.Persisted == false)
                    {
                        <strong class="bad">not granted</strong>
                    }
                    else
                    {
                        <strong class="muted">unknown</strong>
                    }
                </div>
                @if (_storage.UsageBytes is long usage && _storage.QuotaBytes is long quota)
                {
                    <div><span class="muted">Quota</span><strong>@FormatBytes(usage) / @FormatBytes(quota)</strong></div>
                }
            </div>
            @if (_storage.DbBytes == 0)
            {
                <div class="status error">
                    No database in IndexedDB. Either you haven't added a trade yet, or the
                    browser wiped it. Add one, then reload — if it disappears again, add
                    this app to your home screen and retry.
                </div>
            }
        }
        <div class="form-actions">
            <button class="btn btn-secondary" @onclick="RefreshStorageAsync" disabled="@_isBusy">Refresh</button>
        </div>
    </section>
</div>

@code {
    private string _apiKey = string.Empty;
    private string _model = string.Empty;
    private bool _showKey;
    private bool _isBusy;
    private string? _status;
    private string _statusKind = "info";

    private string _xHandles = string.Empty;
    private string? _handlesStatus;
    private string _handlesStatusKind = "info";

    private string _backendUrl = string.Empty;
    private string? _backendStatus;
    private string _backendStatusKind = "info";

    private BrowserDbPersistence.StorageInfo? _storage;

    protected override async Task OnInitializedAsync()
    {
        _apiKey = await SettingsSvc.GetAsync(SettingsKeys.AiApiKey) ?? string.Empty;
        _model = await SettingsSvc.GetAsync(SettingsKeys.AiModel) ?? Services.GeminiAiService.DefaultModel;
        _xHandles = await SettingsSvc.GetAsync(SettingsKeys.TrustedXHandles) ?? string.Empty;
        _backendUrl = await SettingsSvc.GetAsync(SettingsKeys.SignalsBackendUrl) ?? string.Empty;
        await RefreshStorageAsync();
    }

    private async Task SaveHandlesAsync()
    {
        _isBusy = true;
        try
        {
            // Normalize: strip @, split on comma/whitespace, dedupe case-insensitively,
            // rejoin as a clean comma-separated list the prompt can consume directly.
            var cleaned = string.Join(", ",
                (_xHandles ?? string.Empty)
                    .Split(new[] { ',', ' ', '\n', '\r', '\t' }, StringSplitOptions.RemoveEmptyEntries)
                    .Select(h => h.Trim().TrimStart('@'))
                    .Where(h => h.Length > 0)
                    .Distinct(StringComparer.OrdinalIgnoreCase));

            if (string.IsNullOrWhiteSpace(cleaned))
            {
                await SettingsSvc.RemoveAsync(SettingsKeys.TrustedXHandles);
            }
            else
            {
                await SettingsSvc.SetAsync(SettingsKeys.TrustedXHandles, cleaned);
            }
            _xHandles = cleaned;
            _handlesStatus = "Saved.";
            _handlesStatusKind = "success";
        }
        catch (Exception ex)
        {
            _handlesStatus = ex.Message;
            _handlesStatusKind = "error";
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task RefreshStorageAsync()
    {
        try
        {
            _storage = await Persistence.GetStorageInfoAsync();
        }
        catch
        {
            _storage = null;
        }
    }

    private static string FormatBytes(long? bytes)
    {
        if (bytes is null) return "–";
        var b = bytes.Value;
        if (b < 1024) return $"{b} B";
        if (b < 1024 * 1024) return $"{b / 1024.0:0.#} KB";
        return $"{b / (1024.0 * 1024.0):0.##} MB";
    }

    private async Task SaveAsync()
    {
        _isBusy = true;
        try
        {
            if (string.IsNullOrWhiteSpace(_apiKey))
            {
                await SettingsSvc.RemoveAsync(SettingsKeys.AiApiKey);
            }
            else
            {
                await SettingsSvc.SetAsync(SettingsKeys.AiApiKey, _apiKey.Trim());
            }

            await SettingsSvc.SetAsync(SettingsKeys.AiModel,
                string.IsNullOrWhiteSpace(_model) ? Services.GeminiAiService.DefaultModel : _model.Trim());

            Show("Saved.", "success");
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task TestAsync()
    {
        _isBusy = true;
        Show("Testing…", "info");
        try
        {
            // Save first so the service can read the latest key.
            await SaveAsync();

            var ok = await Ai.TestConnectionAsync();
            Show(ok ? "Connection OK." : "Connection failed. Check the key and model.",
                 ok ? "success" : "error");
        }
        catch (Exception ex)
        {
            Show(ex.Message, "error");
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task ClearAsync()
    {
        _isBusy = true;
        try
        {
            await SettingsSvc.RemoveAsync(SettingsKeys.AiApiKey);
            _apiKey = string.Empty;
            Show("Key removed.", "success");
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void Show(string message, string kind)
    {
        _status = message;
        _statusKind = kind;
    }

    private async Task SaveBackendAsync()
    {
        _isBusy = true;
        try
        {
            var trimmed = (_backendUrl ?? string.Empty).Trim().TrimEnd('/');
            if (string.IsNullOrWhiteSpace(trimmed))
            {
                await SettingsSvc.RemoveAsync(SettingsKeys.SignalsBackendUrl);
                _backendUrl = string.Empty;
                ShowBackend("Cleared. Signals will use direct Gemini calls again.", "success");
            }
            else if (!Uri.TryCreate(trimmed, UriKind.Absolute, out var uri) ||
                     (uri.Scheme != Uri.UriSchemeHttp && uri.Scheme != Uri.UriSchemeHttps))
            {
                ShowBackend("Not a valid http(s) URL.", "error");
            }
            else
            {
                await SettingsSvc.SetAsync(SettingsKeys.SignalsBackendUrl, trimmed);
                _backendUrl = trimmed;
                ShowBackend("Saved.", "success");
            }
        }
        catch (Exception ex)
        {
            ShowBackend(ex.Message, "error");
        }
        finally
        {
            _isBusy = false;
        }
    }

    private async Task TestBackendAsync()
    {
        _isBusy = true;
        ShowBackend("Checking…", "info");
        try
        {
            var url = (_backendUrl ?? string.Empty).Trim().TrimEnd('/');
            if (string.IsNullOrWhiteSpace(url))
            {
                ShowBackend("Enter a URL first.", "error");
                return;
            }

            using var resp = await Http.GetAsync(url + "/health");
            if (resp.IsSuccessStatusCode)
            {
                ShowBackend("Worker is reachable.", "success");
            }
            else
            {
                ShowBackend($"Worker responded with {(int)resp.StatusCode}.", "error");
            }
        }
        catch (Exception ex)
        {
            ShowBackend(ex.Message, "error");
        }
        finally
        {
            _isBusy = false;
        }
    }

    private void ShowBackend(string message, string kind)
    {
        _backendStatus = message;
        _backendStatusKind = kind;
    }
}

<style>
    .settings-page {
        padding: 1.5rem;
        max-width: 720px;
        margin: 0 auto;
    }

    .card {
        background: #1f2328;
        border-radius: 12px;
        padding: 1.5rem;
        margin-bottom: 1rem;
    }

    .card h2 {
        margin-top: 0;
        margin-bottom: 0.5rem;
    }

    .muted { color: #a0a0b0; }

    .form-row {
        margin-bottom: 1rem;
    }

    .form-row label {
        display: block;
        font-size: 0.85rem;
        color: #a0a0b0;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        margin-bottom: 0.3rem;
    }

    .form-control {
        background: #14161a;
        border: 1px solid #2a2f36;
        color: #f0f0f5;
        border-radius: 8px;
        padding: 0.6rem 0.75rem;
        width: 100%;
    }

    .form-control:focus { border-color: #4ade80; outline: none; }

    .key-row {
        display: flex;
        gap: 0.5rem;
    }

    .key-row .form-control { flex: 1; }

    .hint {
        font-size: 0.8rem;
        color: #8a8a99;
        margin: 0.3rem 0 0 0;
    }

    .hint code {
        background: #14161a;
        padding: 0.1rem 0.35rem;
        border-radius: 4px;
    }

    .form-actions {
        display: flex;
        gap: 0.5rem;
        flex-wrap: wrap;
        margin-top: 1rem;
    }

    .btn {
        padding: 0.6rem 1rem;
        border-radius: 8px;
        font-weight: 600;
        cursor: pointer;
        border: 1px solid transparent;
    }

    .btn-primary {
        background: #4ade80;
        color: #052e16;
        border-color: #4ade80;
    }

    .btn-secondary {
        background: transparent;
        color: #f0f0f5;
        border-color: #2a2f36;
    }

    .btn-danger {
        background: transparent;
        color: #f87171;
        border-color: #f87171;
    }

    .btn:disabled { opacity: 0.6; cursor: not-allowed; }

    .status {
        margin-top: 1rem;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        font-size: 0.9rem;
    }

    .status.success { background: #14532d; color: #4ade80; }
    .status.error { background: #7f1d1d; color: #f87171; }
    .status.info { background: #1e3a5f; color: #93c5fd; }

    .storage-grid {
        display: grid;
        grid-template-columns: repeat(auto-fit, minmax(10rem, 1fr));
        gap: 0.75rem;
        margin-bottom: 0.75rem;
    }

    .storage-grid > div {
        background: #14161a;
        border-radius: 8px;
        padding: 0.6rem 0.75rem;
        display: flex;
        flex-direction: column;
        gap: 0.25rem;
    }

    .storage-grid .muted { font-size: 0.75rem; text-transform: uppercase; letter-spacing: 0.4px; }
    .storage-grid strong.good { color: #4ade80; }
    .storage-grid strong.bad { color: #f87171; }
</style>
