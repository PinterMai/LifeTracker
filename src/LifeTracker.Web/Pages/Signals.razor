@page "/signals"
@using System.Text.Json
@using LifeTracker.Core.Interfaces
@using LifeTracker.Core.Models
@using LifeTracker.Web.Services
@inject IAiService Ai
@inject ISettingsService SettingsSvc
@inject StaticTickerCatalog Catalog
@inject NavigationManager Nav

<PageTitle>Signals</PageTitle>

<div class="signals-page">
    <div class="page-header">
        <h1>Today's picks</h1>
        <p class="muted">
            Gemini reads the last week of posts from your trusted X handles, then
            aggregates them into a short list of tickers worth a closer look.
            Coverage is whatever Google has indexed — not a real-time feed.
        </p>
    </div>

    @if (_handles is null)
    {
        <div class="status info">Loading…</div>
    }
    else if (_handles.Count == 0)
    {
        <div class="status info">
            No handles configured. Open <a href="settings">Settings</a> and paste your
            trusted X handles first.
        </div>
    }
    else
    {
        <div class="handles-summary">
            <strong>@_handles.Count handles:</strong>
            <span class="muted">@string.Join(", ", _handles.Select(h => "@" + h))</span>
        </div>

        <div class="form-actions">
            <button class="btn btn-primary"
                    @onclick="ScanAsync"
                    disabled="@(_isScanning || IsOnCooldown)">
                @(_isScanning ? "Scanning…" : "Scan now")
            </button>
            @if (_lastScan is not null)
            {
                <span class="muted">
                    Last scan: @FormatAgo(_lastScan.Value)
                    @if (IsOnCooldown)
                    {
                        <text> · wait @FormatRemaining() before rescanning</text>
                    }
                </span>
            }
        </div>
        @if (IsOnCooldown)
        {
            <div class="status info">
                Cached result shown. Gemini free tier has a small daily quota,
                so the scan button unlocks @CooldownHours hours after the
                previous scan to avoid burning it on duplicate searches.
            </div>
        }

        @if (_error is not null)
        {
            <div class="status error">@_error</div>
        }

        @if (_scan is not null)
        {
            @if (_scan.Recommendations.Count == 0 && _scan.RawSignals.Count == 0)
            {
                <div class="status info">
                    No ticker mentions found. Either your handles went quiet this week or
                    Google hasn't indexed their recent posts yet.
                </div>
            }
            else
            {
                @if (_scan.Recommendations.Count > 0)
                {
                    <h2 class="section-title">Recommendations</h2>
                    <div class="rec-grid">
                        @foreach (var r in _scan.Recommendations)
                        {
                            <div class="rec-card action-@r.Action.ToString().ToLower()">
                                <div class="rec-head">
                                    <span class="rec-ticker">@r.Ticker</span>
                                    <span class="rec-action">@r.Action.ToString().ToUpper()</span>
                                </div>
                                <p class="rec-reasoning">@r.Reasoning</p>
                                @if (r.SupportingHandles.Count > 0)
                                {
                                    <div class="rec-supporters">
                                        <span class="muted">From:</span>
                                        @string.Join(", ", r.SupportingHandles.Select(h => "@" + h))
                                    </div>
                                }
                                <div class="rec-actions">
                                    <button class="btn btn-link"
                                            @onclick="() => OpenTradeForTicker(r.Ticker)">
                                        Start trade →
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                }

                @if (_scan.RawSignals.Count > 0)
                {
                    <details class="raw-signals">
                        <summary>
                            Raw mentions (@_scan.RawSignals.Count)
                            <span class="muted">— what each handle actually said</span>
                        </summary>
                        <div class="signal-grid">
                            @foreach (var s in _scan.RawSignals)
                            {
                                <div class="signal-card sentiment-@s.Sentiment.ToString().ToLower()">
                                    <div class="signal-head">
                                        <span class="ticker">@s.Ticker</span>
                                        <span class="sentiment">@s.Sentiment</span>
                                    </div>
                                    <div class="handle">@@@s.Handle</div>
                                    <blockquote class="quote">@s.Quote</blockquote>
                                    <div class="signal-actions">
                                        @if (s.SourceUrl is { Length: > 0 } url)
                                        {
                                            <a class="source" href="@url" target="_blank" rel="noopener">view on X</a>
                                        }
                                        <button class="btn btn-link" @onclick="() => OpenTradeForTicker(s.Ticker)">
                                            Start trade →
                                        </button>
                                    </div>
                                </div>
                            }
                        </div>
                    </details>
                }
            }
        }
    }
</div>

@code {
    // Min hours between scans. Gemini free tier has a tight daily quota
    // for grounded (Google Search) calls and each scan pushes 20+ handles
    // through it — so one accidental double-click can wipe the day's budget.
    private const int CooldownHours = 2;

    private IReadOnlyList<string>? _handles;
    private SignalsScanResult? _scan;
    private DateTime? _lastScan;
    private bool _isScanning;
    private string? _error;

    private bool IsOnCooldown =>
        _lastScan is DateTime ts
        && DateTime.UtcNow - ts < TimeSpan.FromHours(CooldownHours);

    protected override async Task OnInitializedAsync()
    {
        var raw = await SettingsSvc.GetAsync(SettingsKeys.TrustedXHandles) ?? string.Empty;
        _handles = raw
            .Split(new[] { ',', ' ', '\n', '\r', '\t' }, StringSplitOptions.RemoveEmptyEntries)
            .Select(h => h.Trim().TrimStart('@'))
            .Where(h => h.Length > 0)
            .Distinct(StringComparer.OrdinalIgnoreCase)
            .ToArray();

        await HydrateCachedScanAsync();
    }

    /// <summary>
    /// Load the last scan from settings so the page shows results
    /// immediately without hitting Gemini again. Also tolerates an old
    /// cache shape (just SignalCandidate[]) so users on the previous
    /// version don't see an empty page after upgrade.
    /// </summary>
    private async Task HydrateCachedScanAsync()
    {
        var tsRaw = await SettingsSvc.GetAsync(SettingsKeys.LastSignalsScanAt);
        if (DateTime.TryParse(
                tsRaw,
                System.Globalization.CultureInfo.InvariantCulture,
                System.Globalization.DateTimeStyles.AssumeUniversal
                    | System.Globalization.DateTimeStyles.AdjustToUniversal,
                out var ts))
        {
            _lastScan = ts;
        }

        var json = await SettingsSvc.GetAsync(SettingsKeys.LastSignalsResult);
        if (string.IsNullOrWhiteSpace(json)) return;

        try
        {
            // New shape: SignalsScanResult.
            _scan = JsonSerializer.Deserialize<SignalsScanResult>(json);
            if (_scan is null || (_scan.RawSignals.Count == 0 && _scan.Recommendations.Count == 0))
            {
                // Could be old cache (raw array). Try fallback.
                var legacy = JsonSerializer.Deserialize<List<SignalCandidate>>(json);
                if (legacy is { Count: > 0 })
                {
                    _scan = new SignalsScanResult(Array.Empty<Recommendation>(), legacy);
                }
            }
        }
        catch (JsonException)
        {
            // Corrupt cache — ignore, user can just rescan.
            _scan = null;
        }
    }

    private async Task ScanAsync()
    {
        if (_handles is null || _handles.Count == 0) return;
        if (IsOnCooldown) return;

        _isScanning = true;
        _error = null;
        try
        {
            var result = await Ai.ScanSignalsAsync(_handles);
            _scan = result;
            _lastScan = DateTime.UtcNow;

            // Persist so a reload or tab revisit doesn't re-charge Gemini.
            await SettingsSvc.SetAsync(
                SettingsKeys.LastSignalsScanAt,
                _lastScan.Value.ToString("O", System.Globalization.CultureInfo.InvariantCulture));
            await SettingsSvc.SetAsync(
                SettingsKeys.LastSignalsResult,
                JsonSerializer.Serialize(result));

            // Feed every discovered ticker into the catalog so the
            // autocomplete on TradeEdit picks it up without a reload.
            foreach (var s in result.RawSignals)
            {
                await Catalog.AddDiscoveredAsync(
                    new TickerSymbol(s.Ticker, $"{s.Ticker} (from @{s.Handle})", "X Scan"));
            }
        }
        catch (InvalidOperationException ex)
        {
            _error = ex.Message;
        }
        catch (Exception ex)
        {
            _error = $"Scan failed: {ex.Message}";
        }
        finally
        {
            _isScanning = false;
        }
    }

    private void OpenTradeForTicker(string ticker)
    {
        // Deep-link into the new-trade form with the ticker prefilled.
        Nav.NavigateTo($"trades/new?ticker={Uri.EscapeDataString(ticker)}");
    }

    private static string FormatAgo(DateTime utc)
    {
        var diff = DateTime.UtcNow - utc;
        if (diff < TimeSpan.FromMinutes(1)) return "just now";
        if (diff < TimeSpan.FromHours(1)) return $"{(int)diff.TotalMinutes}m ago";
        if (diff < TimeSpan.FromDays(1)) return $"{(int)diff.TotalHours}h ago";
        return utc.ToLocalTime().ToString("yyyy-MM-dd HH:mm");
    }

    private string FormatRemaining()
    {
        if (_lastScan is null) return "";
        var remaining = TimeSpan.FromHours(CooldownHours) - (DateTime.UtcNow - _lastScan.Value);
        if (remaining <= TimeSpan.Zero) return "now";
        return remaining.TotalHours >= 1
            ? $"{(int)remaining.TotalHours}h {remaining.Minutes}m"
            : $"{(int)remaining.TotalMinutes}m";
    }
}

<style>
    .signals-page {
        padding: 1.5rem;
        max-width: 900px;
        margin: 0 auto;
    }

    .page-header h1 { margin-bottom: 0.25rem; }
    .muted { color: #a0a0b0; }

    .handles-summary {
        background: #1f2328;
        padding: 0.75rem 1rem;
        border-radius: 8px;
        margin-bottom: 1rem;
        font-size: 0.9rem;
    }

    .form-actions {
        display: flex;
        align-items: center;
        gap: 1rem;
        margin-bottom: 1rem;
    }

    .section-title {
        font-size: 1.1rem;
        margin: 1.5rem 0 0.75rem;
        color: #f0f0f5;
        letter-spacing: 0.3px;
    }

    .btn-primary {
        padding: 0.6rem 1.25rem;
        background: #4ade80;
        border: none;
        color: #052e16;
        font-weight: 600;
        border-radius: 8px;
        cursor: pointer;
    }

    .btn-primary:disabled { opacity: 0.6; cursor: not-allowed; }

    .btn-link {
        background: transparent;
        border: none;
        color: #93c5fd;
        cursor: pointer;
        padding: 0;
        font-size: 0.85rem;
    }

    .btn-link:hover { text-decoration: underline; }

    .status {
        padding: 0.75rem 1rem;
        border-radius: 8px;
        font-size: 0.9rem;
        margin-bottom: 1rem;
    }

    .status.info { background: #1e3a5f; color: #93c5fd; }
    .status.error { background: #7f1d1d; color: #f87171; }

    /* --- Recommendations (top, prominent) --- */

    .rec-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(18rem, 1fr));
        gap: 0.75rem;
        margin-bottom: 1.5rem;
    }

    .rec-card {
        background: #1f2328;
        border-radius: 12px;
        padding: 1rem 1.1rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        border-left: 4px solid #2a2f36;
    }

    .rec-card.action-long { border-left-color: #4ade80; }
    .rec-card.action-short { border-left-color: #f87171; }
    .rec-card.action-watch { border-left-color: #93c5fd; }
    .rec-card.action-avoid { border-left-color: #f59e0b; }

    .rec-head {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
    }

    .rec-ticker {
        font-size: 1.4rem;
        font-weight: 700;
        letter-spacing: 0.4px;
        color: #f0f0f5;
    }

    .rec-action {
        font-size: 0.75rem;
        font-weight: 700;
        letter-spacing: 0.6px;
        padding: 0.15rem 0.55rem;
        border-radius: 999px;
        background: #2a2f36;
        color: #a0a0b0;
    }

    .rec-card.action-long .rec-action { background: #14532d; color: #4ade80; }
    .rec-card.action-short .rec-action { background: #7f1d1d; color: #f87171; }
    .rec-card.action-watch .rec-action { background: #1e3a5f; color: #93c5fd; }
    .rec-card.action-avoid .rec-action { background: #78350f; color: #f59e0b; }

    .rec-reasoning {
        margin: 0;
        color: #e5e7eb;
        font-size: 0.95rem;
        line-height: 1.45;
    }

    .rec-supporters {
        font-size: 0.8rem;
        color: #93c5fd;
    }

    .rec-supporters .muted { margin-right: 0.3rem; }

    .rec-actions {
        display: flex;
        justify-content: flex-end;
    }

    /* --- Raw signals (collapsed drill-down) --- */

    .raw-signals {
        margin-top: 0.5rem;
        background: #1f2328;
        border-radius: 8px;
        padding: 0.75rem 1rem;
    }

    .raw-signals > summary {
        cursor: pointer;
        font-weight: 600;
        color: #f0f0f5;
        list-style: none;
    }

    .raw-signals > summary::-webkit-details-marker { display: none; }
    .raw-signals > summary::before {
        content: "▸ ";
        color: #a0a0b0;
        margin-right: 0.25rem;
    }

    .raw-signals[open] > summary::before { content: "▾ "; }

    .raw-signals .signal-grid { margin-top: 0.75rem; }

    .signal-grid {
        display: grid;
        grid-template-columns: repeat(auto-fill, minmax(15rem, 1fr));
        gap: 0.75rem;
    }

    .signal-card {
        background: #1f2328;
        border-radius: 10px;
        padding: 0.9rem 1rem;
        display: flex;
        flex-direction: column;
        gap: 0.5rem;
        border-left: 3px solid #2a2f36;
    }

    .raw-signals .signal-card { background: #181c20; }

    .signal-card.sentiment-bullish { border-left-color: #4ade80; }
    .signal-card.sentiment-bearish { border-left-color: #f87171; }
    .signal-card.sentiment-neutral { border-left-color: #93c5fd; }

    .signal-head {
        display: flex;
        justify-content: space-between;
        align-items: baseline;
    }

    .ticker {
        font-size: 1.2rem;
        font-weight: 700;
        letter-spacing: 0.4px;
        color: #f0f0f5;
    }

    .sentiment {
        font-size: 0.75rem;
        text-transform: uppercase;
        letter-spacing: 0.5px;
        color: #a0a0b0;
    }

    .signal-card.sentiment-bullish .sentiment { color: #4ade80; }
    .signal-card.sentiment-bearish .sentiment { color: #f87171; }

    .handle {
        color: #93c5fd;
        font-size: 0.85rem;
    }

    .quote {
        margin: 0;
        color: #e5e7eb;
        font-size: 0.9rem;
        line-height: 1.4;
        font-style: italic;
        border: none;
        padding: 0;
    }

    .signal-actions {
        display: flex;
        justify-content: space-between;
        align-items: center;
        margin-top: 0.25rem;
    }

    .source {
        color: #8a8a99;
        font-size: 0.8rem;
        text-decoration: none;
    }

    .source:hover { color: #93c5fd; text-decoration: underline; }
</style>
